<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Step 1: Select Approved Model -->
    <mxCell id="s1" value="Select Approved Model&#xa;DNDC  |  DayCent  |  RothC  |  CENTURY" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;fontColor=#1e3a5f;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="220" y="30" width="320" height="65" as="geometry"/>
    </mxCell>

    <!-- Step 2: Validate Model -->
    <mxCell id="s2" value="Validate Model&#xa;Peer-reviewed  |  Public  |  Domain-validated" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;fontColor=#5c4a00;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="220" y="145" width="320" height="65" as="geometry"/>
    </mxCell>

    <!-- Step 3: Collect Initial Soil Samples -->
    <mxCell id="s3" value="Collect Initial Soil Samples&#xa;SOC  |  Bulk Density  |  Texture" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;fontColor=#2d5016;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="220" y="260" width="320" height="65" as="geometry"/>
    </mxCell>

    <!-- Step 4a: Run Baseline Scenario -->
    <mxCell id="s4a" value="Run Baseline Scenario&#xa;Same parameters" style="rounded=1;whiteSpace=wrap;fillColor=#e8eaf6;strokeColor=#5c6bc0;fontStyle=1;fontSize=13;fontColor=#283593;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="70" y="390" width="250" height="65" as="geometry"/>
    </mxCell>

    <!-- Step 4b: Run Project Scenario -->
    <mxCell id="s4b" value="Run Project Scenario&#xa;Same parameters" style="rounded=1;whiteSpace=wrap;fillColor=#e8eaf6;strokeColor=#5c6bc0;fontStyle=1;fontSize=13;fontColor=#283593;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="440" y="390" width="250" height="65" as="geometry"/>
    </mxCell>

    <!-- Step 5: Estimate GHG Fluxes -->
    <mxCell id="s5" value="Estimate GHG Fluxes&#xa;SOC + CH&#x2084; + N&#x2082;O&#xa;Most comprehensive approach" style="rounded=1;whiteSpace=wrap;fillColor=#c8e6c9;strokeColor=#2e7d32;fontStyle=1;fontSize=13;fontColor=#1b5e20;spacingTop=4;spacingBottom=4;arcSize=20;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="210" y="520" width="340" height="75" as="geometry"/>
    </mxCell>

    <!-- Step 6: 5-Year Check-In (diamond) -->
    <mxCell id="s6" value="5-Year&#xa;Check-In?" style="rhombus;whiteSpace=wrap;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=13;fontColor=#bf360c;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="305" y="655" width="150" height="110" as="geometry"/>
    </mxCell>

    <!-- Step 7: Re-Sample Soil -->
    <mxCell id="s7" value="Re-Sample Soil&#xa;True-up the model" style="rounded=1;whiteSpace=wrap;fillColor=#fce4ec;strokeColor=#c2185b;fontStyle=1;fontSize=13;fontColor=#880e4f;spacingTop=4;spacingBottom=4;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="560" y="680" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Arrow: S1 to S2 -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S2 to S3 -->
    <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S3 to S4a (left branch) -->
    <mxCell id="e3a" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4a" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S3 to S4b (right branch) -->
    <mxCell id="e3b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4b" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S4a to S5 -->
    <mxCell id="ea5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5c6bc0;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s4a" target="s5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S4b to S5 -->
    <mxCell id="eb5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#5c6bc0;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s4b" target="s5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S5 to S6 -->
    <mxCell id="e56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2e7d32;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s5" target="s6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: S6 to S7 (Yes - Every 5 years) -->
    <mxCell id="e67" value="Every 5 years" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#e65100;strokeWidth=2;fontSize=11;fontColor=#bf360c;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s6" target="s7" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Dashed arrow: S7 back up to S4a/S4b area (Recalibrate) -->
    <mxCell id="eloop" value="Recalibrate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#c2185b;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=11;fontColor=#880e4f;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s7" target="s4b" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="810" y="710"/>
          <mxPoint x="810" y="423"/>
        </Array>
      </mxGeometry>
    </mxCell>

  </root>
</mxGraphModel>
