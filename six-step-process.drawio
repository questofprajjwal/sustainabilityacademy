<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Step 1 -->
    <mxCell id="s1" value="Step 1&#xa;Review Accounting&#xa;Steps &amp; Principles" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;fontColor=#1e3a5f;" vertex="1" parent="1">
      <mxGeometry x="100" y="40" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Step 2 -->
    <mxCell id="s2" value="Step 2&#xa;Identify Scope 3&#xa;Activities" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;fontColor=#2d5016;" vertex="1" parent="1">
      <mxGeometry x="360" y="40" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Step 3 -->
    <mxCell id="s3" value="Step 3&#xa;Set the Scope 3&#xa;Boundary" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;fontColor=#5c4a00;" vertex="1" parent="1">
      <mxGeometry x="620" y="40" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Step 4 -->
    <mxCell id="s4" value="Step 4&#xa;Collect Data" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;fontColor=#5c1a18;" vertex="1" parent="1">
      <mxGeometry x="620" y="200" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Step 5 -->
    <mxCell id="s5" value="Step 5&#xa;Apply Calculation&#xa;Methods" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;fontColor=#3d1f56;" vertex="1" parent="1">
      <mxGeometry x="360" y="200" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Step 6 -->
    <mxCell id="s6" value="Step 6&#xa;Allocate Emissions" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;fontColor=#5c3d00;" vertex="1" parent="1">
      <mxGeometry x="100" y="200" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Arrows: S1 -> S2 -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- S2 -> S3 -->
    <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- S3 -> S4 (down) -->
    <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- S4 -> S5 (left) -->
    <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s4" target="s5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- S5 -> S6 (left) -->
    <mxCell id="e56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s5" target="s6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Iterative arrow: S6 back to S4 (dashed) -->
    <mxCell id="eiter" value="Iterative" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;strokeWidth=1.5;dashed=1;fontColor=#666666;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="s6" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="190" y="310"/>
          <mxPoint x="710" y="310"/>
        </Array>
      </mxGeometry>
    </mxCell>

  </root>
</mxGraphModel>
